// Ele usa o JOIN para "unir" as três tabelas (jogos, generos e produtoras) e mostrar os nomes escritos em vez de apenas os números dos IDs.
SELECT 
    j.id, 
    j.nome, 
    g.genero, 
    p.produtora, 
    j.descricao, 
    j.nota 
FROM jogos j
JOIN generos g ON j.genero = g.id
JOIN produtora p ON j.produtora = p.id;