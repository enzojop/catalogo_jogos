//CRIAR O BANCO DE DADOS:

create database bd_catalogo default character set utf8 collate utf8_general_ci;

//CRIAR A TABELA USUARIOS:

create table usuarios (
usuario varchar(10) not null,
nome varchar(30) not null,
senha varchar(60) not null,
tipo varchar(10) not null default 'editor',
primary key(usuario)
) engine=InnoDB default charset=utf8;

// CRIAR A TABELA DE GENEROS DOS JOGOS:

create table generos (
id int (11) not null,
genero varchar(20) not null,
primary key(id)
) engine=InnoDB default charset=utf8;

// CRIA A TABELA DE PRODUTORA:

create table produtora (
id int(11) not null,
produtora varchar(20) not null,
pais varchar(20) not null,
primary key(id)
) engine=InnoDB default charset=utf8;

// CRIAR A TABELA JOGOS COM SUAS CHAVES ESTRANGEIRAS:

create table jogos(
id int(11) not null,
nome varchar(40) not null,
genero int(11) not null,
produtora int(11) not null,
descricao text not null,
nota decimal(4,2) default null,
primary key(id),
foreign key(genero) references generos(id),
foreign key(produtora) references produtora(id)
) engine=InnoDB default charset=utf8;



